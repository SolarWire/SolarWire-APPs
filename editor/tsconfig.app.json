{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "./dist/app",
    "types": ["vite/client"]
  },
  "include": ["src/app/**/*", "src/shared/**/*", "src/types/**/*"],
  "exclude": ["node_modules", "dist", "src/app/components/editor/SolarWireCanvas.tsx"]
}
