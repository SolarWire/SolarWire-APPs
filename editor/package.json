{
  "name": "solarwire-editor",
  "version": "0.1.14",
  "description": "SolarWire Editor - A complete document workspace",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --prefix-colors green,blue --prefix \"[{name}]\" --names \"vite,electron\" \"npm run vite\" \"npm run electron:dev\"",
    "dev:win": "concurrently --kill-others-on-fail --prefix-colors green,blue --prefix \"[{name}]\" --names \"vite,electron\" \"npm run vite\" \"npm run electron:dev\" ",
    "vite": "vite",
    "electron:dev": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && node src/main/wait-for-vite.js && electron --disable-gpu dist/main/index.js",
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && tsc -p tsconfig.app.json && vite build && electron-builder",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "lint:styles": "stylelint \"src/**/*.css\"",
    "lint:styles:fix": "stylelint \"src/**/*.css\" --fix",
    "lint:all": "npm run lint && npm run lint:styles",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "typecheck:all": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@solarwire/parser": "file:../../SolarWire/packages/core/parser",
    "@solarwire/renderer-svg": "file:../../SolarWire/packages/core/renderer-svg",
    "@types/papaparse": "^5.5.2",
    "@viz-js/viz": "^3.26.0",
    "commit-graph": "^2.4.0",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.5",
    "mermaid": "^11.14.0",
    "monaco-editor": "^0.55.1",
    "papaparse": "^5.5.3",
    "react": "^19.2.5",
    "react-colorful": "^5.6.1",
    "react-datasheet-grid": "^4.11.6",
    "react-dom": "^19.2.5",
    "solarwire": "github:SolarWire/SolarWire",
    "xlsx": "^0.18.5",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/marked": "^5.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "concurrently": "^8.2.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-css-modules": "^2.12.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^29.0.2",
    "pegjs": "^0.10.0",
    "playwright": "^1.59.1",
    "postcss": "^8.4.38",
    "postcss-modules": "^6.0.0",
    "prettier": "^3.2.5",
    "stylelint": "^16.3.1",
    "stylelint-config-css-modules": "^4.4.0",
    "stylelint-config-recommended": "^14.0.0",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-order": "^6.0.4",
    "stylelint-prettier": "^5.0.0",
    "typescript": "^5.2.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.4"
  }
}
