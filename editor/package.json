{
  "name": "solarwire-editor",
  "version": "0.1.0",
  "description": "SolarWire Editor - A complete document workspace",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run vite & npm run electron:dev",
    "dev:win": "start npm run vite && timeout /t 3 && npm run electron:dev",
    "vite": "vite",
    "electron:dev": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && electron --disable-gpu dist/main/index.js",
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && tsc -p tsconfig.app.json && vite build && electron-builder",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@solarwire/parser": "file:../../SolarWire/packages/core/parser",
    "@solarwire/renderer-svg": "file:../../SolarWire/packages/core/renderer-svg",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.5",
    "mermaid": "^11.14.0",
    "monaco-editor": "^0.55.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "simple-git": "^3.22.0",
    "solarwire": "github:SolarWire/SolarWire",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/lodash-es": "^4.17.12",
    "@types/marked": "^5.0.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "concurrently": "^8.2.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "typescript": "^5.2.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.4"
  }
}
