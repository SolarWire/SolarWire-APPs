"¥89,012" @(170, 42) c=#333333 size=22 bold=true
"+8%" @(250, 55) c=#52c41a size=12
("") @(310, 10) w=140 h=80 bg=#ffffff s=1 r=6
"订单量" @(320, 20) c=#999999 size=12
